{
  "name": "executor-v2",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@effect/platform": "^0.93.6",
    "@effect/vitest": "^0.27.0",
    "@types/node": "^20.19.9",
    "effect": "^3.19.8",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "turbo run dev --parallel",
    "typecheck": "turbo run typecheck",
    "env:pull:development": "better-env pull --environment development",
    "env:pull:preview": "better-env pull --environment preview",
    "env:pull:production": "better-env pull --environment production",
    "env:validate:development": "bun tools/validate-env-workspaces.ts development",
    "env:validate:production": "bun tools/validate-env-workspaces.ts production",
    "knip": "bunx knip --config knip.json",
    "db:env:pull:prod": "bun run env:pull:production",
    "db:migrate:prod": "bun run env:pull:production && bun run --filter=@executor-v2/persistence-sql --env-file=.env.production db:migrate"
  },
  "devDependencies": {
    "@effect/language-service": "^0.76.0",
    "@types/bun": "^1.2.22",
    "@types/node": "catalog:",
    "turbo": "^2.8.11",
    "typescript": "catalog:"
  },
  "dependencies": {
    "better-env": "^0.3.1",
    "vercel": "^50.23.2"
  }
}
