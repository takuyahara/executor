{
  "name": "executor",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "packages/*",
    "apps/*",
    "apps/docs"
  ],
  "catalog": {
    "@effect/cli": "^0.73.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@effect/vitest": "^0.27.0",
    "@types/node": "^24.3.1",
    "bun-types": "^1.2.22",
    "effect": "^3.19.19",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "scripts": {
    "dev": "turbo run dev",
    "trace:up": "docker compose -f compose.tracing.yaml up -d",
    "trace:down": "docker compose -f compose.tracing.yaml down",
    "docs:dev": "turbo run dev --filter=@executor/docs",
    "test": "turbo run test",
    "executor": "./apps/executor/bin/executor",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release:pre:enter": "changeset pre enter beta",
    "release:pre:exit": "changeset pre exit",
    "typecheck": "bun run --filter='*' typecheck",
    "knip": "knip"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "knip": "^5.85.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.3"
  }
}
