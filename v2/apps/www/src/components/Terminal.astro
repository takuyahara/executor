---

<div class="animate-fade-up-delay w-screen ml-[calc(-50vw+50%)]">
  <div class="bg-surface-elevated border-t border-white/[0.06] overflow-hidden relative after:content-[''] after:absolute after:bottom-0 after:left-0 after:right-0 after:h-20 after:bg-gradient-to-b after:from-transparent after:to-surface after:pointer-events-none">
    <div class="bg-white/[0.02] px-12 py-3.5 flex gap-1.5 border-b border-white/[0.06] max-sm:px-6">
      <div class="w-2.5 h-2.5 rounded-full bg-gray-500 opacity-60"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-gray-500 opacity-60"></div>
      <div class="w-2.5 h-2.5 rounded-full bg-gray-500 opacity-60"></div>
    </div>
    <div class="px-12 py-5 h-[480px] overflow-hidden relative max-sm:px-4 max-sm:h-[200px] after:content-[''] after:absolute after:bottom-0 after:left-0 after:right-0 after:h-[140px] after:bg-gradient-to-b after:from-transparent after:to-surface-elevated after:pointer-events-none">
      <div class="animate-scroll-logs">
        {allLines.map((line) => (
          <div class="font-mono text-xs leading-8 whitespace-nowrap text-white/40 max-sm:text-[0.65rem]">
            <span class="text-white/20 mr-4">{line.time}</span>
            <span class:list={["inline-block w-[52px] mr-4", line.levelClass]}>{line.level}</span>
            <span class="text-white/50">{line.msg}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
